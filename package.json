{
  "name": "@fluq/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Fluq agent observability platform",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "fluq",
    "agent",
    "observability",
    "tracing",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fluq-ai/fluq-js.git"
  },
  "homepage": "https://fluq.ai",
  "bugs": {
    "url": "https://github.com/fluq-ai/fluq-js/issues"
  }
}